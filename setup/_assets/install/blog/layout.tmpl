<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>{{ .Home.Name }}</title>
    <meta name="description" content="{{.Home.Detail}}">
    <style>
      body { max-width: 720px; margin: 0 auto; padding: 1em; font-family: sans-serif; }
      header { border-bottom: 1px solid #ccc; margin-bottom: 1em; }
      .post-meta { color: #666; font-size: 0.9em; margin-bottom: 1em; }
    </style>
  </head>
  <body>
    <header>
      <h1><a href="/">{{ .Home.Name }}</a></h1>
    </header>
    {{ template "Content" . }}
  </body>
</html>
